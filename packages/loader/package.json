{
  "name": "@statics-lead/loader",
  "version": "0.1.0",
  "description": "Browser runtime for strategyAssets() — fetch and cache 3D/static assets via manifest.json",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "build:bundle": "esbuild src/index.ts --bundle --format=esm --outfile=loader.bundle.js --platform=browser --minify",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.6.0",
    "esbuild": "^0.27.4",
    "happy-dom": "^20.8.4",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "3d",
    "assets",
    "loader",
    "cdn",
    "cache",
    "manifest"
  ],
  "license": "MIT"
}
